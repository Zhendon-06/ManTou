<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ManTou" parent="Theme.Material3.Light.NoActionBar">
        <!-- Force light theme even in night mode -->
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="android:alertDialogTheme">@style/ThemeOverlay.ManTou.GlassAlertDialog</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.ManTou.GlassAlertDialog</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.ManTou.GlassAlertDialog</item>
    </style>
</resources>
